
add component -type Python -name Simulator
add port -componentName Simulator -name SimPort -gateway python2DtCan

add component -type Python -name Controller
add port -componentName Controller -name CtrlPort -gateway python2DtCan

add component -type Python -name Plotter
add port -componentName Plotter -name PlotPort -gateway python2DtCan

define componentSignals -componentName Simulator -signals "[cmd_vel:double[2]:input,robot_pose:double[3]:output,reference_path:double[3]:output]"
define componentSignals -componentName Controller -signals "[cmd_vel:double[2]:output,robot_pose:double[3]:input,reference_path:double[3]:input]"
define componentSignals -componentName Plotter -signals "[cmd_vel:double[2]:input,robot_pose:double[3]:input,reference_path:double[3]:input]"

define frame -componentName Simulator -portName SimPort -id 10 -signals [cmd_vel:0:64]
define frame -componentName Controller -portName CtrlPort -id 10 -signals [cmd_vel:0:64]
define frame -componentName Plotter -portName PlotPort -id 10 -signals [cmd_vel:0:64]

define frame -componentName Simulator -portName SimPort -id 11 -signals [robot_pose:0:64]
define frame -componentName Controller -portName CtrlPort -id 11 -signals [robot_pose:0:64]
define frame -componentName Plotter -portName PlotPort -id 11 -signals [robot_pose:0:64]

define frame -componentName Simulator -portName SimPort -id 12 -signals [reference_path:0:64]
define frame -componentName Controller -portName CtrlPort -id 12 -signals [reference_path:0:64]
define frame -componentName Plotter -portName PlotPort -id 12 -signals [reference_path:0:64]


set totalSimTime 70 s
set simulationStep 0.001 s

set workspaceDir .
set digitalTwinName Line_Following_Robot
generate


